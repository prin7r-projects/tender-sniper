# Public app URL used in NOWPayments redirects + IPN callback URLs.
# Default to the deployed origin; override on storage-contabo if proxying.
NEXT_PUBLIC_SITE_URL=https://tender-sniper.prin7r.com

# NOWPayments — hosted invoice rail (USDT/USDC + card on-ramp).
# https://nowpayments.io/
# Read by apps/landing/lib/nowpayments.ts via apps/landing/lib/env.ts.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=false
